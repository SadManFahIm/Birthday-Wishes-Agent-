# .streamlit/secrets.toml
# ─────────────────────────────────────────────────────────────
# This file stores your secrets for Streamlit Cloud deployment.
#
# ⚠️  IMPORTANT:
#   - NEVER commit secrets.toml to GitHub!
#   - It is already in .gitignore
#   - On Streamlit Cloud, add these via:
#     App Settings → Secrets → paste the content below
# ─────────────────────────────────────────────────────────────

GOOGLE_API_KEY       = "your_google_api_key"
OPENAI_API_KEY       = "your_openai_api_key"

USERNAME             = "your_linkedin_email"
PASSWORD             = "your_linkedin_password"

GITHUB_URL           = "https://github.com/SadManFahIm"

FB_USERNAME          = "your_facebook_email"
FB_PASSWORD          = "your_facebook_password"

IG_USERNAME          = "your_instagram_username"
IG_PASSWORD          = "your_instagram_password"

TELEGRAM_BOT_TOKEN   = "your_telegram_bot_token"
TELEGRAM_CHAT_ID     = "your_telegram_chat_id"

EMAIL_SENDER         = "your_gmail@gmail.com"
EMAIL_PASSWORD       = "your_app_password"
EMAIL_RECEIVER       = "receiver@example.com"

ELEVENLABS_API_KEY   = ""
ELEVENLABS_VOICE_ID  = "21m00Tcm4TlvDq8ikWAM"
