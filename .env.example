# LLM API Keys (choose one)
OPENAI_API_KEY=
GOOGLE_API_KEY=

# LinkedIn credentials
USERNAME=your_linkedin_email
PASSWORD=your_linkedin_password

# GitHub URL
GITHUB_URL=https://github.com/SadManFahIm

# Facebook Messenger credentials
FB_USERNAME=your_facebook_email
FB_PASSWORD=your_facebook_password

# Instagram credentials
IG_USERNAME=your_instagram_username
IG_PASSWORD=your_instagram_password

# Telegram Notification
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email Notification (Gmail App Password)
EMAIL_SENDER=your_gmail@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_RECEIVER=receiver@example.com

# Voice Message (ElevenLabs - optional, premium)
# Get API key from https://elevenlabs.io
# Voice ID list: https://api.elevenlabs.io/v1/voices
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Birthday Reminder Email Recipients (comma-separated)
REMINDER_RECIPIENTS=your_email@gmail.com,spouse@gmail.com

# Weekly Health Report Recipients (comma-separated)
REPORT_RECIPIENTS=your_email@gmail.com

# Voice-to-Text (Google Speech API - optional)
# If not set, Whisper (free, local) will be used instead
GOOGLE_SPEECH_API_KEY=
